# Upbit API credentials
# config.json의 exchange.key/secret 대신 환경변수로 주입
FREQTRADE__EXCHANGE__KEY=your_upbit_access_key
FREQTRADE__EXCHANGE__SECRET=your_upbit_secret_key

# API Server (optional)
FREQTRADE__API_SERVER__JWT_SECRET_KEY=changeme
FREQTRADE__API_SERVER__WS_TOKEN=changeme_ws
FREQTRADE__API_SERVER__PASSWORD=changeme
