# =============================================================================
# crypto-autotrader environment template — copy to .env and fill in
# Freqtrade reads FREQTRADE__SECTION__KEY → config[section][key] (double-underscore)
# =============================================================================

# Upbit API credentials (required for live; can be blank for dry_run)
FREQTRADE__EXCHANGE__KEY=your_upbit_access_key
FREQTRADE__EXCHANGE__SECRET=your_upbit_secret_key

# Telegram alerts (recommended for 24/7 unattended runs)
#   Create bot via @BotFather  →  copy token
#   Get chat_id via @userinfobot  (or @get_id_bot)
FREQTRADE__TELEGRAM__TOKEN=
FREQTRADE__TELEGRAM__CHAT_ID=

# API Server — IMPORTANT: rotate before enabling api_server.enabled=true
FREQTRADE__API_SERVER__JWT_SECRET_KEY=ROTATE_ME_TO_A_LONG_RANDOM_STRING
FREQTRADE__API_SERVER__WS_TOKEN=ROTATE_ME_WS_TOKEN
FREQTRADE__API_SERVER__USERNAME=freqtrader
FREQTRADE__API_SERVER__PASSWORD=ROTATE_ME_STRONG_PASSWORD
